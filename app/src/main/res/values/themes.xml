<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ════════════════════════════════════════════════════════════════════
         Base Theme (Light)
         ════════════════════════════════════════════════════════════════════ -->

    <style name="Theme.CompanionOverlay" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary: gold accent -->
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryContainer">@color/surface_variant</item>
        <item name="colorOnPrimary">@color/on_gold</item>
        <item name="colorOnPrimaryContainer">@color/gold</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/gold_variant</item>
        <item name="colorSecondaryContainer">@color/surface_variant</item>
        <item name="colorOnSecondary">@color/on_gold</item>
        <item name="colorOnSecondaryContainer">@color/gold_variant</item>

        <!-- Surface -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/navigation_bar</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Accent for legacy views -->
        <item name="colorAccent">@color/gold</item>

        <!-- Preference theming -->
        <item name="preferenceTheme">@style/CompanionPreferenceTheme</item>

        <!-- Default text colors -->
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Transitions -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowEnterTransition">@transition/fade_in</item>
        <item name="android:windowExitTransition">@transition/fade_out</item>
        <item name="android:windowSharedElementEnterTransition">@transition/shared_element</item>
        <item name="android:windowSharedElementExitTransition">@transition/shared_element</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Transparent Theme (for AssistActivity)
         ════════════════════════════════════════════════════════════════════ -->

    <style name="Theme.Transparent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Preference Theme
         ════════════════════════════════════════════════════════════════════ -->

    <style name="CompanionPreferenceTheme" parent="PreferenceThemeOverlay.v14.Material">
        <item name="android:scrollbars">none</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Dialog Theme - background matches app
         ════════════════════════════════════════════════════════════════════ -->

    <style name="CompanionDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/background</item>
        <item name="colorSurfaceContainerHigh">@color/background</item>
        <item name="colorSurfaceContainer">@color/background</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorPrimary">@color/gold</item>
        <item name="dialogCornerRadius">20dp</item>
        <item name="android:background">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Button Styles
         ════════════════════════════════════════════════════════════════════ -->

    <style name="CompanionButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/button_toggle_text</item>
        <item name="backgroundTint">@color/button_toggle_background</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="CompanionButton.Large" parent="CompanionButton">
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="CompanionButton.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/gold</item>
        <item name="strokeColor">@color/gold</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="CompanionButton.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/gold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="rippleColor">@color/gold_ripple</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Card Styles
         ════════════════════════════════════════════════════════════════════ -->

    <style name="CompanionCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="rippleColor">@color/gold_ripple</item>
    </style>

    <style name="CompanionCard.Flat" parent="CompanionCard">
        <item name="cardElevation">0dp</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Text Styles
         ════════════════════════════════════════════════════════════════════ -->

    <style name="TextAppearance.Companion.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/gold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Companion.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/gold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Companion.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextAppearance.Companion.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Dropdown Style
         ════════════════════════════════════════════════════════════════════ -->

    <style name="CompanionDropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/dropdown_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

</resources>
