<?xml version="1.0" encoding="utf-8"?>
<!-- Faint gold "floor" glow under the sprite's walk line. Positioned at
     runtime (the walk line's Y is computed from sprite metrics). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="@android:color/transparent"
        android:endColor="@color/tutorial_floor"/>
</shape>
