<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="8dp">

    <com.google.android.material.card.MaterialCardView
        style="@style/CompanionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:baselineAligned="false">

            <!-- Idle Sprite -->
            <FrameLayout
                android:id="@+id/idleSpriteCard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/idleSpritePreview"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="Idle sprite"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="idle"
                        android:textAppearance="@style/TextAppearance.Companion.LabelSmall"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </FrameLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="16dp"
                android:background="@color/sprite_divider"/>

            <!-- Walk Sprite -->
            <FrameLayout
                android:id="@+id/walkSpriteCard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/walkSpritePreview"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="Walk sprite"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="walk"
                        android:textAppearance="@style/TextAppearance.Companion.LabelSmall"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
