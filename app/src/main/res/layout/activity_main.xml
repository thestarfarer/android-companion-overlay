<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ════════════════════════════════════════════════════════════════
             Top Bar
             ════════════════════════════════════════════════════════════════ -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <View
                android:id="@+id/authDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/auth_dot"
                android:layout_marginEnd="8dp"
                android:transitionName="auth_dot"/>

            <TextView
                android:id="@+id/authStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/main_gateway_not_configured"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:singleLine="true"/>

            <ImageView
                android:id="@+id/settingsButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_settings"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/main_settings_button"
                app:tint="@color/text_secondary"/>

        </LinearLayout>

        <!-- ════════════════════════════════════════════════════════════════
             Scrollable Content
             ════════════════════════════════════════════════════════════════ -->

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
            android:scrollbarSize="4dp"
            android:fadeScrollbars="true"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="32dp">

                <!-- ════════════════════════════════════════════════════════
                     Preset Header
                     ════════════════════════════════════════════════════════ -->

                <LinearLayout
                    android:id="@+id/presetHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/presetName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/main_preset_name_default"
                        android:textAppearance="@style/TextAppearance.Companion.HeadlineLarge"
                        android:transitionName="preset_name"/>

                    <TextView
                        android:id="@+id/presetSwitcher"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▾"
                        android:textSize="18sp"
                        android:textColor="@color/text_secondary"
                        android:paddingHorizontal="8dp"/>

                </LinearLayout>

                <!-- ════════════════════════════════════════════════════════
                     Preset Carousel (ViewPager2)
                     ════════════════════════════════════════════════════════ -->

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/presetPager"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginHorizontal="16dp"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:overScrollMode="never"/>

                <!-- Page Indicator -->
                <LinearLayout
                    android:id="@+id/pageIndicatorContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingTop="12dp"
                    android:paddingBottom="16dp"/>

                <!-- ════════════════════════════════════════════════════════
                     System Prompt Card
                     ════════════════════════════════════════════════════════ -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/systemPromptCard"
                    style="@style/CompanionCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/systemPromptTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/main_system_prompt_title"
                            android:textAppearance="@style/TextAppearance.Companion.TitleMedium"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:id="@+id/systemPromptPreview"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Companion.BodyMedium"
                            android:maxLines="3"
                            android:ellipsize="end"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ════════════════════════════════════════════════════════
                     User Message Card
                     ════════════════════════════════════════════════════════ -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/userMessageCard"
                    style="@style/CompanionCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginBottom="24dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/userMessageTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/main_user_message_title"
                            android:textAppearance="@style/TextAppearance.Companion.TitleMedium"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:id="@+id/userMessagePreview"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Companion.BodyMedium"
                            android:maxLines="2"
                            android:ellipsize="end"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ════════════════════════════════════════════════════════
                     Status + Toggle
                     ════════════════════════════════════════════════════════ -->

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:text="@string/main_status_sleeping"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/toggleButton"
                    style="@style/CompanionButton.Large"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:text="@string/main_toggle_wake"/>

                <!-- ════════════════════════════════════════════════════════
                     Gateway Setup Button (when needed)
                     Anchored last so its show/hide never reflows the controls
                     above it — only grows the scroll content at the bottom.
                     marginTop (not Bottom) gives the gap from the toggle, so a
                     gone button leaves no dangling space.
                     ════════════════════════════════════════════════════════ -->

                <Button
                    android:id="@+id/authButton"
                    style="@style/CompanionButton.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/main_setup_gateway"
                    android:visibility="gone"/>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
