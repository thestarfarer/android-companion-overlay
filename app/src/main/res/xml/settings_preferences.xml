<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- ════════ GEMINI API ════════ -->
    <PreferenceCategory app:iconSpaceReserved="false" app:title="@string/pref_cat_gemini_api">

        <Preference
            app:iconSpaceReserved="false"
            app:key="gemini_api_key"
            app:title="@string/pref_gemini_api_key_title"
            app:summary="@string/pref_gemini_api_key_summary"/>

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="gemini_stt_enabled"
            app:title="@string/pref_gemini_stt_title"
            app:summary="@string/pref_gemini_stt_summary"
            app:defaultValue="false"/>

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="gemini_tts_enabled"
            app:title="@string/pref_gemini_tts_title"
            app:summary="@string/pref_gemini_tts_summary"
            app:defaultValue="false"/>

    </PreferenceCategory>


    <!-- ════════ DISPLAY ════════ -->
    <PreferenceCategory app:iconSpaceReserved="false" app:title="@string/pref_cat_display">

        <ListPreference
            app:iconSpaceReserved="false"
            app:key="overlay_mode"
            app:title="@string/pref_overlay_mode_title"
            app:summary="@string/pref_overlay_mode_summary"
            app:entries="@array/overlay_mode_entries"
            app:entryValues="@array/overlay_mode_values"
            app:defaultValue="sprite"
            app:persistent="true"/>

        <ListPreference
            app:iconSpaceReserved="false"
            app:key="capture_mode"
            app:title="@string/pref_capture_mode_title"
            app:summary="%s"
            app:entries="@array/capture_mode_entries"
            app:entryValues="@array/capture_mode_values"
            app:defaultValue="screenshot"
            app:persistent="true"/>

    </PreferenceCategory>

    <!-- ════════ VOICE INPUT ════════ -->
    <PreferenceCategory app:iconSpaceReserved="false" app:title="@string/pref_cat_voice_input">

        <SeekBarPreference
            app:iconSpaceReserved="false"
            app:key="silence_timeout_seek"
            app:title="@string/pref_silence_timeout_title"
            app:summary="@string/pref_silence_timeout_summary"
            android:max="50"
            app:min="1"
            app:defaultValue="15"
            app:persistent="false"/>

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="voice_screenshot_enabled"
            app:title="@string/pref_voice_screenshot_title"
            app:summary="@string/pref_voice_screenshot_summary"
            app:defaultValue="false"/>

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="volume_toggle_enabled"
            app:title="@string/pref_volume_toggle_title"
            app:summary="@string/pref_volume_toggle_summary"
            app:defaultValue="true"/>

    </PreferenceCategory>

    <!-- ════════ VOICE OUTPUT ════════ -->
    <PreferenceCategory app:iconSpaceReserved="false" app:title="@string/pref_cat_voice_output">

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="tts_enabled"
            app:title="@string/pref_tts_enabled_title"
            app:summary="@string/pref_tts_enabled_summary"
            app:defaultValue="true"/>

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="beeps_enabled"
            app:title="@string/pref_beeps_title"
            app:summary="@string/pref_beeps_summary"
            app:defaultValue="true"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="tts_voice_picker"
            app:title="@string/pref_tts_voice_picker_title"
            app:summary="@string/pref_tts_voice_picker_summary"/>

    </PreferenceCategory>

    <!-- ════════ CONVERSATION ════════ -->
    <PreferenceCategory app:iconSpaceReserved="false" app:title="@string/pref_cat_conversation">

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="web_search_enabled"
            app:title="@string/pref_web_search_title"
            app:summary="@string/pref_web_search_summary"
            app:defaultValue="false"/>

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="keep_dialogue"
            app:title="@string/pref_keep_dialogue_title"
            app:summary="@string/pref_keep_dialogue_summary"
            app:defaultValue="false"/>

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="auto_copy"
            app:title="@string/pref_auto_copy_title"
            app:summary="@string/pref_auto_copy_summary"
            app:defaultValue="false"/>

        <ListPreference
            app:iconSpaceReserved="false"
            app:key="max_messages"
            app:title="@string/pref_max_messages_title"
            app:summary="@string/pref_max_messages_summary"
            app:entries="@array/history_labels"
            app:entryValues="@array/history_values"
            app:defaultValue="20"
            app:persistent="false"/>

        <ListPreference
            app:iconSpaceReserved="false"
            app:key="bubble_timeout"
            app:title="@string/pref_bubble_timeout_title"
            app:summary="@string/pref_bubble_timeout_summary"
            app:entries="@array/timeout_labels"
            app:entryValues="@array/timeout_values"
            app:defaultValue="30"
            app:persistent="false"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="clear_history"
            app:title="@string/pref_clear_history_title"
            app:summary="@string/pref_clear_history_summary"/>

    </PreferenceCategory>

    <!-- ════════ MCP SERVERS ════════ -->
    <PreferenceCategory app:iconSpaceReserved="false" app:title="@string/pref_cat_mcp_servers">

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="mcp_enabled"
            app:title="@string/pref_mcp_enabled_title"
            app:summary="@string/pref_mcp_enabled_summary"
            app:defaultValue="false"/>

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="mcp_show_tool_bubbles"
            app:title="@string/pref_mcp_show_tool_bubbles_title"
            app:summary="@string/pref_mcp_show_tool_bubbles_summary"
            app:defaultValue="true"
            app:dependency="mcp_enabled"/>

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="nexus_integration_enabled"
            app:title="@string/pref_nexus_integration_title"
            app:summary="@string/pref_nexus_integration_summary"
            app:defaultValue="false"
            app:dependency="mcp_enabled"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="nexus_context_prompt"
            app:title="@string/pref_nexus_context_prompt_title"
            app:summary="@string/pref_nexus_context_prompt_summary"
            app:dependency="nexus_integration_enabled"/>

        <com.starfarer.companionoverlay.ui.LongClickPreference
            app:iconSpaceReserved="false"
            app:key="nexus_fetch_context"
            app:title="@string/pref_nexus_fetch_context_title"
            app:summary="@string/pref_nexus_fetch_context_summary"
            app:dependency="nexus_integration_enabled"/>

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="nexus_context_append_to_prompt"
            app:title="@string/pref_nexus_context_append_title"
            app:summary="@string/pref_nexus_context_append_summary"
            app:defaultValue="true"
            app:dependency="nexus_integration_enabled"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="mcp_manage_servers"
            app:title="@string/pref_mcp_manage_servers_title"
            app:summary="@string/pref_mcp_manage_servers_summary"
            app:dependency="mcp_enabled"/>

    </PreferenceCategory>

    <!-- ════════ PERMISSIONS ════════ -->
    <PreferenceCategory app:iconSpaceReserved="false" app:title="@string/pref_cat_permissions">

        <Preference
            app:iconSpaceReserved="false"
            app:key="perm_accessibility"
            app:title="@string/pref_perm_accessibility_title"
            app:summary="@string/pref_perm_accessibility_summary"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="perm_voice"
            app:title="@string/pref_perm_voice_title"
            app:summary="@string/pref_perm_voice_summary"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="perm_camera"
            app:title="@string/pref_perm_camera_title"
            app:summary="@string/pref_perm_camera_summary"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="perm_notifications"
            app:title="@string/pref_perm_notifications_title"
            app:summary="@string/pref_perm_notifications_summary"/>

    </PreferenceCategory>

    <!-- ════════ CLAUDE API ════════ -->
    <PreferenceCategory app:iconSpaceReserved="false" app:key="account_category" app:title="@string/pref_cat_claude_api">

        <Preference
            app:iconSpaceReserved="false"
            app:key="claude_api_key"
            app:title="@string/pref_claude_api_key_title"
            app:summary="@string/pref_claude_api_key_summary"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="claude_connection_type"
            app:title="@string/pref_claude_connection_type_title"
            app:summary="@string/pref_claude_connection_type_summary"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="account_auth"
            app:title="@string/pref_account_auth_title"
            app:summary="@string/pref_account_auth_summary"/>

    </PreferenceCategory>

    <!-- ════════ ABOUT ════════ -->
    <PreferenceCategory app:iconSpaceReserved="false" app:title="@string/pref_cat_about">

        <Preference
            app:iconSpaceReserved="false"
            app:key="tutorial"
            app:title="@string/pref_tutorial_title"
            app:summary="@string/pref_tutorial_summary"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="open_source_licenses"
            app:title="@string/pref_open_source_licenses_title"
            app:summary="@string/pref_open_source_licenses_summary"/>

    </PreferenceCategory>

    <!-- ════════ DEBUG ════════ -->
    <PreferenceCategory app:iconSpaceReserved="false" app:title="@string/pref_cat_debug">

        <Preference
            app:iconSpaceReserved="false"
            app:key="debug_test"
            app:title="@string/pref_debug_test_title"
            app:summary="@string/pref_debug_test_summary"/>

        <SwitchPreferenceCompat
            app:iconSpaceReserved="false"
            app:key="save_sent_images"
            app:title="@string/pref_save_sent_images_title"
            app:summary="@string/pref_save_sent_images_summary"
            app:defaultValue="false"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="debug_view_image"
            app:title="@string/pref_debug_view_image_title"
            app:summary="@string/pref_debug_view_image_summary"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="debug_copy_log"
            app:title="@string/pref_debug_copy_log_title"
            app:summary="@string/pref_debug_copy_log_summary"/>

        <Preference
            app:iconSpaceReserved="false"
            app:key="debug_clear_log"
            app:title="@string/pref_debug_clear_log_title"
            app:summary="@string/pref_debug_clear_log_summary"/>

    </PreferenceCategory>

</PreferenceScreen>
